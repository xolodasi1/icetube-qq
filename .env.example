# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APPWRITE_ENDPOINT: Define the API endpoint of the targeted Appwrite server.
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"

# APPWRITE_PROJECT_ID: Define the project ID
VITE_APPWRITE_PROJECT_ID="your_project_id_here"

# APPWRITE_DATABASE_ID: The ID of your Appwrite Database
VITE_APPWRITE_DATABASE_ID="your_database_id_here"

# APPWRITE_USERS_COLLECTION_ID: The ID of the generic public users collection
VITE_APPWRITE_USERS_COLLECTION_ID="your_users_collection_id"

# APPWRITE_VIDEOS_COLLECTION_ID: The ID of the Appwrite videos collection
VITE_APPWRITE_VIDEOS_COLLECTION_ID="your_videos_collection_id_here"

# APPWRITE_COMMENTS_COLLECTION_ID: The ID for video comments
VITE_APPWRITE_COMMENTS_COLLECTION_ID="your_comments_collection_id"

# APPWRITE_LIKES_COLLECTION_ID: The ID for liking videos
VITE_APPWRITE_LIKES_COLLECTION_ID="your_likes_collection_id"

# APPWRITE_SUBS_COLLECTION_ID: The ID for channel subscriptions
VITE_APPWRITE_SUBS_COLLECTION_ID="your_subs_collection_id"

# APPWRITE_REPORTS_COLLECTION_ID: The ID for video reports/complaints
VITE_APPWRITE_REPORTS_COLLECTION_ID="your_reports_collection_id"

# CLOUDINARY_CLOUD_NAME: Your Cloudinary cloud name (e.g. dxxxxxxxx)
VITE_CLOUDINARY_CLOUD_NAME="your_cloud_name_here"

# CLOUDINARY_UPLOAD_PRESET: A predefined upload preset with "Unsigned" signing mode
VITE_CLOUDINARY_UPLOAD_PRESET="your_upload_preset_here"
